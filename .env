# Real Ring Partner API credentials, issued once at
# developer.amazon.com/ring/console/apps when you register the app.
RING_CLIENT_ID=ring_client_id
RING_CLIENT_SECRET=ring_client_secret

# Used to verify the account-link nonce and webhook signatures.
RING_HMAC_SIGNING_KEY=ring_hmac_signing_key

# Signs the RingBoard session cookie - separate from anything Ring issues.
# Generate your own random value, e.g. `openssl rand -base64 32`.
SESSION_SECRET=ring_session_secret

# Upstash Redis / Vercel KV instance (Vercel dashboard -> Storage -> Create
# Database -> KV) for unclaimed tokens, partner accounts, and Ring links.
KV_REST_API_URL=kv_rest_api_url
KV_REST_API_TOKEN=kv_rest_api_token
