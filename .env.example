# Real Ring Partner API credentials, issued once at
# developer.amazon.com/ring/console/apps when you register the app. Shown
# only once at registration time - if lost, you'll need to regenerate them
# from the portal.
RING_CLIENT_ID=your_partner_client_id
RING_CLIENT_SECRET=your_partner_client_secret

# Used to verify the account-link nonce (api/_auth/nonce.ts) and webhook
# signatures (api/ring/webhook.ts). Also issued once at app registration.
RING_HMAC_SIGNING_KEY=your_partner_hmac_signing_key

# Signs the RingBoard session cookie (api/_auth/session.ts) - this is
# separate from anything Ring issues. Generate your own random value, e.g.
# `openssl rand -base64 32`.
SESSION_SECRET=generate_a_random_secret

# Upstash Redis / Vercel KV instance used to hold unclaimed OAuth tokens,
# partner accounts, and active Ring links (api/_kv.ts). Create one via the
# Vercel dashboard -> Storage -> Create Database -> KV, which injects these
# automatically for deployed environments; set them here for local dev.
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
